# Si quieres usar MongoDB Atlas, copia este contenido a .env
# y reemplaza <username>, <password> y <cluster> con tus datos reales

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/coffeeguard?retryWrites=true&w=majority
JWT_SECRET=coffee-guard-jwt-secret-key-2026-super-secure
JWT_EXPIRES_IN=7d
PORT=8080

# Ejemplo:
# MONGODB_URI=mongodb+srv://coffeeguard-admin:CoffeeGuard2026!@coffeeguard.h8rgvj7.mongodb.net/coffeeguard?retryWrites=true&w=majority
